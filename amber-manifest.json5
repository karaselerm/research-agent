{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      openrouter_api_key: { type: "string", secret: true },
      openrouter_model: { type: "string" },
    },
    required: [],
    additionalProperties: false,
  },

  slots: {},

  program: {
    image: "ghcr.io/karaselerm/research-agent:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      OPENROUTER_API_KEY: "${config.openrouter_api_key}",
      OPENROUTER_MODEL: "${config.openrouter_model}",
    },

    network: {
      endpoints: [{ name: "a2a_endpoint", port: 9009 }],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
