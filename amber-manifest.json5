{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      routerai_api_key: { type: "string", secret: true },
      routerai_model: { type: "string", default: "openai/gpt-5.4-mini" },
      routerai_base_url: { type: "string", default: "https://routerai.ru/api/v1" },
      // Backward compatibility with older config names.
      openrouter_api_key: { type: "string", secret: true },
      openrouter_model: { type: "string" },
    },
    required: [],
    additionalProperties: false,
  },

  slots: {},

  program: {
    image: "ghcr.io/karaselerm/research-agent:latest",
    entrypoint: [
      "uv",
      "run",
      "python",
      "src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "9009",
    ],

    env: {
      ROUTERAI_API_KEY: "${config.routerai_api_key}",
      ROUTERAI_MODEL: "${config.routerai_model}",
      ROUTERAI_BASE_URL: "${config.routerai_base_url}",
      // Legacy env vars are still exported for compatibility.
      OPENROUTER_API_KEY: "${config.openrouter_api_key}",
      OPENROUTER_MODEL: "${config.openrouter_model}",
    },

    network: {
      endpoints: [{ name: "a2a_endpoint", port: 9009 }],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
